# Copy to .env and fill in values. Do not commit .env.
#
# For `docker compose`: if any value contains `$`, write `$$` instead of `$` in this file,
# or Compose will try to expand it when parsing the compose file.

NODE_ENV=production
APP_NAME=Gloup
APP_PORT=5678
# Port on your machine when using Docker (maps to APP_PORT in the container)
HOST_PORT=5678

# Production database (see config/config.js)
DB_HOST=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Development DB (when NODE_ENV is not production)
# DEV_DB_HOST=
# DEV_DB_NAME=
# DEV_DB_USERNAME=
# DEV_DB_PASSWORD=

# Payments and other integrations — add keys your deployment uses.
# RZ_PAY_ID=
# RZ_PAY_KEY=
# RZ_WEBHOOK_SECRET=  # Razorpay Dashboard → Settings → Webhooks → Secret
# JOINING_FEE_RAZORPAY_PLAN_ID=  # optional Razorpay plan id for first-invoice joining fee addon

# Google Cloud Storage (public URLs must include the bucket name)
# GCS_PROJECT_ID=project-981a5f33-4fa3-4d79-ab5
# GCS_BUCKET=gloup-images
# GCS_BASE_URL=https://storage.googleapis.com/gloup-images
# GOOGLE_APPLICATION_CREDENTIALS=config/firebase.json
