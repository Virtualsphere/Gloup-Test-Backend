{"nodes": [{"id": "docs_admin_targeted_notification_api_send_targeted_notification", "label": "Admin Send Targeted Notification API", "file_type": "concept", "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /admin/app/send-targeted-notification sends FCM push to ONE user or partner. In-app notification log is always written; push is best-effort \u2014 missing FCM token returns HTTP 201, not 400, so the recipient still sees the message in-app."}, {"id": "docs_admin_targeted_notification_api_broadcast_notification", "label": "Admin Broadcast Notification API", "file_type": "concept", "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /admin/app/addnotification targets many users/partners (sent_to: all/user/store), in contrast to the single-recipient targeted API."}, {"id": "docs_admin_targeted_notification_api_fcm_token_pruning", "label": "FCM Token Pruning", "file_type": "rationale", "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Invalid/stale FCM tokens are removed from the database after failed sends (e.g. messaging/registration-token-not-registered). Only the latest stored token per recipient is used to avoid duplicate notifications on the same phone."}, {"id": "docs_admin_targeted_notification_api_device_id_registration", "label": "Device ID (FCM Token) Registration", "file_type": "concept", "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /user/auth/deviceId and /partner/auth/deviceId register FCM tokens; each call replaces the previous token so one active token is kept per user/store."}], "edges": [{"source": "docs_admin_targeted_notification_api_send_targeted_notification", "target": "docs_admin_targeted_notification_api_broadcast_notification", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "weight": 1.0}, {"source": "docs_admin_targeted_notification_api_fcm_token_pruning", "target": "docs_admin_targeted_notification_api_send_targeted_notification", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "weight": 1.0}, {"source": "docs_admin_targeted_notification_api_fcm_token_pruning", "target": "docs_admin_targeted_notification_api_broadcast_notification", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "weight": 1.0}, {"source": "docs_admin_targeted_notification_api_device_id_registration", "target": "docs_admin_targeted_notification_api_send_targeted_notification", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/admin-targeted-notification-api.md", "source_location": null, "weight": 1.0}], "hyperedges": []}